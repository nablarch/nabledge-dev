      },
      "when": {
        "workflow": "qa",
        "input": "Nablarchバッチアプリケーションはどのように起動しますか？-requestPathの書き方を教えてください",
        "expected_hearing": "should_skip"
      },
      "then": {
        "must": [
          {
            "fact": "javaコマンドから直接起動するスタンドアロンアプリケーションとして実行する",
            "section": "processing-pattern/nablarch-batch/nablarch-batch-architecture.json:s1"
          },
          {
            "fact": "-requestPathコマンドライン引数でアクションのクラス名とリクエストIDを指定する",
            "section": "processing-pattern/nablarch-batch/nablarch-batch-architecture.json:s2"
          }
        ],
        "acceptable": [
          {
            "section": "processing-pattern/nablarch-batch/nablarch-batch-architecture.json:s3"
          }
        ]
      }
    },
