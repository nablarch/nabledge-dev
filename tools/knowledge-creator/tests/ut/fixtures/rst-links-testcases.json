{
  "comment": "Real-world RST link patterns extracted from Nablarch official documentation for testing Phase G link resolution",
  "extracted_from": ".lw/nab-official/v5/nablarch-document/ja/**/*.rst",
  "total_rst_files": 431,
  "patterns": {
    "ref": {
      "description": "Cross-reference to labels (internal or external)",
      "syntax": [
        ":ref:`label`",
        ":ref:`display text <label>`"
      ],
      "examples": [
        {
          "rst": ":ref:`repository`",
          "note": "Simple reference without display text"
        },
        {
          "rst": ":ref:`RESTfulウェブサービス <restful_web_service>`",
          "note": "Reference with custom display text"
        },
        {
          "rst": ":ref:`HTTPアクセスログ <http_access_log>`",
          "note": "Reference with Japanese display text"
        },
        {
          "rst": ":ref:`thread_context_handler`",
          "note": "Reference to handler (likely external)"
        },
        {
          "rst": ":ref:`http_error_handler`",
          "note": "Reference to another handler"
        },
        {
          "rst": ":ref:`http_access_log-session_store_id`",
          "note": "Reference with hyphenated label (could be internal or external)"
        },
        {
          "rst": ":ref:`micrometer_default_metrics`",
          "note": "Reference with underscores"
        },
        {
          "rst": ":ref:`ファクトリ<repository-factory_injection>`",
          "note": "Japanese text with hyphenated label"
        }
      ],
      "resolution_rules": {
        "internal": "Label defined in same file → [display](#section-id)",
        "external": "Label defined in other file → [display](path/to/file.md#section-id)",
        "display_text": "Use custom text if provided, otherwise use section title"
      }
    },
    "doc": {
      "description": "Link to document by path",
      "syntax": [
        ":doc:`path`",
        ":doc:`display text <path>`"
      ],
      "examples": [
        {
          "rst": ":doc:`コンセプト <about_nablarch/concept>`",
          "note": "Relative path with display text",
          "path_type": "relative"
        },
        {
          "rst": ":doc:`モジュール一覧 <about_nablarch/mvn_module>`",
          "note": "Relative path with display text",
          "path_type": "relative"
        },
        {
          "rst": ":doc:`解説書 <application_framework/application_framework/index>`",
          "note": "Multi-level relative path",
          "path_type": "relative"
        },
        {
          "rst": ":doc:`nablarch_batch/index`",
          "note": "Simple reference without display text",
          "path_type": "relative"
        },
        {
          "rst": ":doc:`feature_details/database_reader`",
          "note": "Relative path without extension",
          "path_type": "relative"
        }
      ],
      "resolution_rules": {
        "path": "Convert RST path to MD path (doc_path.rst → doc_path.md)",
        "relative": "Resolve relative paths from source file location",
        "absolute": "Paths starting with / are from doc root",
        "display_text": "Use custom text if provided, otherwise use target document title"
      }
    },
    "download": {
      "description": "Link to downloadable file",
      "syntax": [
        ":download:`display text <path>`"
      ],
      "examples": [
        {
          "rst": ":download:`デフォルト設定一覧 <../../configuration/デフォルト設定一覧.xlsx>`",
          "note": "Excel file with relative path",
          "file_type": "xlsx"
        },
        {
          "rst": ":download:`デフォルト設定一覧.xlsx <デフォルト設定一覧.xlsx>`",
          "note": "Same directory file",
          "file_type": "xlsx"
        },
        {
          "rst": ":download:`プロジェクト一括登録.csv<../downloads/project_upload/プロジェクト一括登録.csv>`",
          "note": "CSV file with relative path",
          "file_type": "csv"
        },
        {
          "rst": ":download:`create.jsp <../downloads/client_create/create.jsp>`",
          "note": "JSP source file",
          "file_type": "jsp"
        },
        {
          "rst": ":download:`全リリースノート一括ダウンロード <./nablarch-5-OSS-all-releasenote.zip>`",
          "note": "ZIP archive",
          "file_type": "zip"
        },
        {
          "rst": ":download:`リリースノート(5u26) <./nablarch5u26-releasenote.xlsx>`",
          "note": "Version-specific file",
          "file_type": "xlsx"
        }
      ],
      "resolution_rules": {
        "format": "[display](assets/{FILE_ID}/filename)",
        "note": "Files should be extracted to assets directory during Phase B"
      }
    },
    "java_extdoc": {
      "description": "Link to external Javadoc (Nablarch custom domain)",
      "syntax": [
        ":java:extdoc:`fully.qualified.ClassName`",
        ":java:extdoc:`display text <fully.qualified.ClassName>`"
      ],
      "examples": [
        {
          "rst": ":java:extdoc:`nablarch.common.web.handler.HttpAccessLogHandler`",
          "note": "Simple class reference",
          "package": "nablarch"
        },
        {
          "rst": ":java:extdoc:`ThreadContext <nablarch.core.ThreadContext>`",
          "note": "With custom display text",
          "package": "nablarch"
        },
        {
          "rst": ":java:extdoc:`ThymeleafResponseWriter<nablarch.fw.web.handler.responsewriter.thymeleaf.ThymeleafResponseWriter>`",
          "note": "Long class name with display",
          "package": "nablarch"
        },
        {
          "rst": ":java:extdoc:`ComponentFactory<nablarch.core.repository.di.ComponentFactory>`",
          "note": "Interface reference",
          "package": "nablarch"
        },
        {
          "rst": ":java:extdoc:`JaxRsMethodBinderFactory#handlerList <nablarch.fw.jaxrs.JaxRsMethodBinderFactory.setHandlerList(java.util.List)>`",
          "note": "Method reference with signature",
          "package": "nablarch",
          "type": "method"
        },
        {
          "rst": ":java:extdoc:`TemplateEngineProcessedResult#valueOf<nablarch.common.mail.TemplateEngineProcessedResult.valueOf(java.lang.String)>`",
          "note": "Method with parameters",
          "package": "nablarch",
          "type": "method"
        }
      ],
      "resolution_rules": {
        "url_mapping": "Use javadoc_url_map from conf.py to resolve package prefix to base URL",
        "format": "https://nablarch.github.io/docs/LATEST/javadoc/nablarch/core/ThreadContext.html",
        "add_to_official_doc_urls": true,
        "in_text": "Keep only class name as inline code: `ClassName`"
      },
      "javadoc_url_map": {
        "nablarch": "https://nablarch.github.io/docs/LATEST/javadoc/",
        "java": "https://docs.oracle.com/javase/8/docs/api/",
        "javax": "https://docs.oracle.com/javase/8/docs/api",
        "javax.persistence": "https://docs.oracle.com/javaee/7/api/",
        "javax.validation": "https://docs.oracle.com/javaee/7/api/",
        "javax.servlet": "https://docs.oracle.com/javaee/7/api/",
        "javax.batch": "https://docs.oracle.com/javaee/7/api/",
        "javax.inject": "https://docs.oracle.com/javaee/7/api/",
        "javax.enterprise": "https://docs.oracle.com/javaee/7/api/",
        "javax.ws": "https://docs.oracle.com/javaee/7/api/"
      }
    },
    "external_url": {
      "description": "External HTTP/HTTPS URLs",
      "syntax": [
        "`text (外部サイト) <url>`_"
      ],
      "examples": [
        {
          "rst": "`Fintan(外部サイト) <https://fintan.jp/>`_",
          "note": "Japanese site marker"
        },
        {
          "rst": "`Thymeleaf(外部サイト) <https://www.thymeleaf.org>`_",
          "note": "External library"
        },
        {
          "rst": "`Jersey(外部サイト、英語) <https://eclipse-ee4j.github.io/jersey/>`_",
          "note": "English site marker"
        },
        {
          "rst": "`Jackson(外部サイト、英語) <https://github.com/FasterXML/jackson>`_",
          "note": "GitHub repository"
        },
        {
          "rst": "`Micrometer(外部サイト、英語) <https://micrometer.io/>`_",
          "note": "External documentation"
        },
        {
          "rst": "https://jvndb.jvn.jp/ja/contents/2019/JVNDB-2019-012258.html",
          "note": "Bare URL (security advisory)"
        }
      ],
      "resolution_rules": {
        "format": "[text](url)",
        "note": "Convert RST link format to Markdown, keep URL unchanged"
      }
    },
    "label_definitions": {
      "description": "Label definitions in RST files",
      "syntax": ".. _label_name:",
      "examples": [
        ".. _http_access_log_handler:",
        ".. _thread_context_handler:",
        ".. _micrometer_adaptor:",
        ".. _micrometer_default_metrics:",
        ".. _repository:",
        ".. _restful_web_service:",
        ".. _mail_sender_freemarker_adaptor:",
        ".. _jaxrs_adaptor:"
      ],
      "usage": "Used to build global label index in Phase G for resolving :ref: links"
    }
  },
  "test_scenarios": {
    "scenario_1": {
      "name": "Internal reference resolution",
      "description": "Label defined in same file, should resolve to #anchor",
      "source_file": "handlers/http_access_log_handler.rst",
      "label_defined": "http_access_log_handler",
      "reference": ":ref:`http_access_log_handler`",
      "expected": "[HTTPアクセスログハンドラ](#overview)"
    },
    "scenario_2": {
      "name": "External reference resolution",
      "description": "Label defined in other file, should resolve to file.md#anchor",
      "source_file": "handlers/http_access_log_handler.rst",
      "label_defined_in": "handlers/thread_context_handler.rst",
      "reference": ":ref:`thread_context_handler`",
      "expected": "[スレッドコンテキストハンドラ](../handlers/common/thread-context-handler.md#overview)"
    },
    "scenario_3": {
      "name": "Doc link resolution",
      "description": ":doc: should resolve to target file path",
      "source_file": "index.rst",
      "reference": ":doc:`application_framework/application_framework/index`",
      "expected": "[解説書](application_framework/application_framework/index.md)"
    },
    "scenario_4": {
      "name": "Download link resolution",
      "description": ":download: should point to assets directory",
      "source_file": "configuration/index.rst",
      "file_id": "configuration-index",
      "reference": ":download:`デフォルト設定一覧.xlsx <デフォルト設定一覧.xlsx>`",
      "expected": "[デフォルト設定一覧.xlsx](assets/configuration-index/デフォルト設定一覧.xlsx)"
    },
    "scenario_5": {
      "name": "Java extdoc resolution",
      "description": ":java:extdoc: should generate Javadoc URL and add to official_doc_urls",
      "reference": ":java:extdoc:`nablarch.core.ThreadContext`",
      "expected_in_text": "`ThreadContext`",
      "expected_in_urls": "https://nablarch.github.io/docs/LATEST/javadoc/nablarch/core/ThreadContext.html"
    },
    "scenario_6": {
      "name": "External URL preservation",
      "description": "External URLs should be converted to Markdown format",
      "reference": "`Fintan(外部サイト) <https://fintan.jp/>`_",
      "expected": "[Fintan(外部サイト)](https://fintan.jp/)"
    }
  }
}
