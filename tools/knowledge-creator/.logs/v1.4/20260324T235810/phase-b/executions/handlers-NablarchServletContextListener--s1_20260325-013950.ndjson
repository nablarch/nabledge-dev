sitoryBasedWebFrontController</filter-class>\n  </filter>\n\n  <filter-mapping>\n    <filter-name>controller</filter-name>\n    <url-pattern>/*</url-pattern>\n  </filter-mapping>\n</web-app>\n```"}}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":17925,"cache_read_input_tokens":18643,"cache_creation":{"ephemeral_5m_input_tokens":17925,"ephemeral_1h_input_tokens":0},"output_tokens":8},"context_management":null},"parent_tool_use_id":null,"session_id":"77b1994d-4dc7-45dc-aef8-b84982bf7073","uuid":"1e6b85dd-e7a5-4434-9a8e-3d3805b55796"}
