| パス | 内容 |\n|---|---|\n| /WEB-INF/tags/widget/event/confirm.tag | このイベントアクションの実体となるタグファイル |\n| /WEB-INF/tags/widget/event/dialog.tag | :doc:`event_alert` と :doc:`event_confirm` とで共通の内容を実装するタグファイル |\n| /js/nablarch/ui/event/ShowDialogAction.js | ダイアログ表示機能を実装するJS部品 |"}}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":17940,"cache_read_input_tokens":18643,"cache_creation":{"ephemeral_5m_input_tokens":17940,"ephemeral_1h_input_tokens":0},"output_tokens":8},"context_management":null},"parent_tool_use_id":null,"session_id":"d0b7437f-691d-4c3f-ab11-6c57cb70d2f4","uuid":"cdfd1c56-b48f-4c64-a382-38772b588839"}
