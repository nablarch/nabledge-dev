 actual parameters themselves are documented, I think it's reasonable to omit the tool-specific navigation details. The core technical information is there—what matters is knowing which JVM option or system property to set, not necessarily the exact menu clicks in Eclipse.","signature":""}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":19931,"cache_read_input_tokens":18561,"cache_creation":{"ephemeral_5m_input_tokens":19931,"ephemeral_1h_input_tokens":0},"output_tokens":8},"context_management":null},"parent_tool_use_id":null,"session_id":"80af5953-1a95-4476-9009-88110867e9ab","uuid":"337481d0-c1a9-48d9-bd61-299d15d9ab5e"}
