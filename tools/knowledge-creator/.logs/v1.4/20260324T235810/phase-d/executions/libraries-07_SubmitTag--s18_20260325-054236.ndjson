応タグリストの上部に記載されている。","signature":""}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":19759,"cache_read_input_tokens":18561,"cache_creation":{"ephemeral_5m_input_tokens":19759,"ephemeral_1h_input_tokens":0},"output_tokens":8},"context_management":null},"parent_tool_use_id":null,"session_id":"429e1af0-8456-4993-9555-3361cc2851b5","uuid":"689e04ea-b0cd-4033-9c44-8745433e4ee2"}
