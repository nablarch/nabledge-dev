ional—it only shows configuration examples.","signature":""}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":21023,"cache_read_input_tokens":18561,"cache_creation":{"ephemeral_5m_input_tokens":21023,"ephemeral_1h_input_tokens":0},"output_tokens":8},"context_management":null},"parent_tool_use_id":null,"session_id":"851d54bb-4413-48b5-9a10-d9ad71bbf7dd","uuid":"de8d1305-5c64-4d45-b1d1-f4d21d3dbc94"}
