er processing, while resident batches check for new data every second and continue running indefinitely, only waiting when there's no data to process.","signature":""}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":20843,"cache_read_input_tokens":29955,"cache_creation":{"ephemeral_5m_input_tokens":20843,"ephemeral_1h_input_tokens":0},"output_tokens":8},"context_management":null},"parent_tool_use_id":null,"session_id":"98cec63e-575b-4eb1-bcbb-5034c001d377","uuid":"320278fe-fcb8-4ebe-909a-b06fa16c1fcb"}
