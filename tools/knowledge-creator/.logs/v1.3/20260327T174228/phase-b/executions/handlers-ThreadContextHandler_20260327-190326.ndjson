threadcontext.UserIdAttribute\">\n      <property name=\"sessionKey\" value=\"user.id\" />\n      <property name=\"anonymousId\" value=\"guest\" />\n    </component>\n    <!-- 言語 -->\n    <component class=\"nablarch.common.handler.threadcontext.LanguageAttribute\">\n      <property name=\"defaultLanguage\" value=\"ja\" />\n    </component>\n    <!-- タイムゾーン -->\n    <component class=\"nablarch.common.handler.threadcontext.TimeZoneAttribute\">\n      <property name=\"defaultTimeZone\" value=\"Asia/Tokyo\" />\n    </component>\n    <!-- 実行時ID -->\n    <component class=\"nablarch.common.handler.threadcontext.ExecutionIdAttribute\" />\n  </list>\n  </property>\n</component>\n```"}}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":21534,"cache_read_input_tokens":29955,"cache_creation":{"ephemeral_5m_input_tokens":21534,"ephemeral_1h_input_tokens":0},"output_tokens":8},"context_management":null},"parent_tool_use_id":null,"session_id":"69ef0e79-cdca-46ba-a701-c6d4ab04c1af","uuid":"aa29c4f9-f884-404a-ace2-117a85146b0b"}
