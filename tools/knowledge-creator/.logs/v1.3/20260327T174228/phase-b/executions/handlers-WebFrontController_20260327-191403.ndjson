ent-ref name=\"httpResponseHandler\" />\n  </list>\n  </property>\n</component>\n```"}}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":21310,"cache_read_input_tokens":29955,"cache_creation":{"ephemeral_5m_input_tokens":21310,"ephemeral_1h_input_tokens":0},"output_tokens":8},"context_management":null},"parent_tool_use_id":null,"session_id":"c540ba49-436e-4d64-8122-848a6a5c8231","uuid":"1ab62c7d-c5e1-40c0-8c9c-eef9b7889fc9"}
