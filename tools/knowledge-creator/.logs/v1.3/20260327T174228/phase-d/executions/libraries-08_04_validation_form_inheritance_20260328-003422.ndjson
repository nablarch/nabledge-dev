ation that demonstrates this behavior.","signature":""}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":22885,"cache_read_input_tokens":29873,"cache_creation":{"ephemeral_5m_input_tokens":22885,"ephemeral_1h_input_tokens":0},"output_tokens":8},"context_management":null},"parent_tool_use_id":null,"session_id":"911d9a07-3190-4044-a873-6928b93d3eda","uuid":"773d182e-928c-4271-a9b7-f60fe1db89d5"}
