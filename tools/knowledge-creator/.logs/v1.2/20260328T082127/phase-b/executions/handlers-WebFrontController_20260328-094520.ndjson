AccessHandler\" />\n    <component-ref name=\"httpResponseHandler\" />\n    <!-- 以下ハンドラ定義(略) -->\n  </list>\n  </property>\n</component>\n```"}}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":21164,"cache_read_input_tokens":29889,"cache_creation":{"ephemeral_5m_input_tokens":21164,"ephemeral_1h_input_tokens":0},"output_tokens":8},"context_management":null},"parent_tool_use_id":null,"session_id":"7a75f4c8-dfc8-4138-961d-4c0a96850613","uuid":"07da3037-2d93-4443-a7c5-1b3d2f114ad3"}
