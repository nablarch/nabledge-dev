# Local work directory (.lw/ is excluded except all-releasenote xlsx files)
.lw/*
!.lw/nab-official/
.lw/nab-official/*
!.lw/nab-official/all-releasenote/
.lw/nab-official/all-releasenote/**/*.zip

# Temporary directory (test workspaces, etc.)
.tmp/

# PR skill temporary state
.pr/

# RBKC internal state (source file snapshots for update/delete diff)
.state/

# Claude Code local settings
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Environment variables
.env
.nabledge/

# Python
*.pyc
__pycache__/
.venv/
venv/
.pytest_cache/

# DeepEval internal cache
.deepeval/
# Locally-generated Javadoc knowledge (RBKC output, reverted for PR review)
.claude/skills/nabledge-5/docs/javadoc/
.claude/skills/nabledge-5/knowledge/javadoc/
