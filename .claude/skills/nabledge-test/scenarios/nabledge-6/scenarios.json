      "benchmark": true,
      "question": "コード値のプルダウン入力を実装するには？",
      "expectations": {
        "code_select_tag": ["n:codeSelect", "codeId", "pattern"],
        "general_select_tag": ["n:select", "listName", ["elementValueProperty", "elementLabelProperty"]],
        "concepts": ["コード値", "withNoneOption"]
      }
    },
