{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "File Scoring Schema",
  "description": "Schema for file relevance scoring in keyword search",
  "type": "object",
  "properties": {
    "query": {
      "type": "string",
      "description": "User's original query"
    },
    "keywords": {
      "type": "object",
      "properties": {
        "l1": {
          "type": "array",
          "items": {"type": "string"},
          "description": "L1 keywords (technical components)"
        },
        "l2": {
          "type": "array",
          "items": {"type": "string"},
          "description": "L2 keywords (functional terms)"
        }
      },
      "required": ["l1", "l2"]
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "Relative path to knowledge file"
          },
          "title": {
            "type": "string",
            "description": "File title"
          },
          "hints": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Search hints for this file"
          },
          "score": {
            "type": "number",
            "description": "Relevance score (L1 match=2, L2 match=1)"
          }
        },
        "required": ["path", "title", "hints", "score"]
      }
    }
  },
  "required": ["query", "keywords", "files"]
}
