{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Section Scoring Schema",
  "description": "Schema for section relevance scoring in keyword search",
  "type": "object",
  "properties": {
    "query": {
      "type": "string",
      "description": "User's original query"
    },
    "keywords": {
      "type": "object",
      "properties": {
        "l1": {
          "type": "array",
          "items": {"type": "string"}
        },
        "l2": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "required": ["l1", "l2"]
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "file_path": {
            "type": "string",
            "description": "Knowledge file path"
          },
          "section_id": {
            "type": "string",
            "description": "Section identifier"
          },
          "hints": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Search hints for this section"
          },
          "relevance": {
            "type": "integer",
            "minimum": 0,
            "maximum": 3,
            "description": "Relevance score: 3=high, 2=medium, 1=low, 0=none"
          },
          "reasoning": {
            "type": "string",
            "description": "Brief explanation for the score"
          }
        },
        "required": ["file_path", "section_id", "hints", "relevance", "reasoning"]
      }
    }
  },
  "required": ["query", "keywords", "sections"]
}
